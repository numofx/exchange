# Runs the staleness check every minute.
# Install: cp scripts/ops/numo-feed-alert.{service,timer} /etc/systemd/system/
#          systemctl daemon-reload && systemctl enable --now numo-feed-alert.timer
[Unit]
Description=Numo feed staleness check every minute

[Timer]
OnBootSec=1min
OnUnitActiveSec=1min
AccuracySec=10s

[Install]
WantedBy=timers.target
